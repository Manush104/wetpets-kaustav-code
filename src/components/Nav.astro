---
import { categoryTree } from '../data/products';

const currentPath = Astro.url.pathname;

const links = [
  { href: '/wetpets-kaustav-code/',          label: 'Home' },
  { href: '/wetpets-kaustav-code/products',  label: 'Products', hasMega: true },
  { href: '/wetpets-kaustav-code/about',     label: 'About' },
  { href: '/wetpets-kaustav-code/contact',   label: 'Contact' },
];
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <!-- Logo -->
    <a href="/wetpets-kaustav-code/" class="nav__logo" id="nav-logo">
      <span class="nav__logo-mark">WP</span>
      <div class="nav__logo-text">
        <span class="nav__logo-name">Wet Pets</span>
        <span class="nav__logo-sub">Aquarium Store</span>
      </div>
    </a>

    <!-- Desktop links -->
    <nav class="nav__links" id="nav-links" aria-label="Main navigation">
      <button class="nav__search-btn" id="search-trigger-desktop" aria-label="Search products" title="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      
      {links.map((l) => (
        <div class={`nav__link-wrap ${l.hasMega ? 'nav__link-wrap--mega' : ''}`}>
          <a
            href={l.href}
            class:list={['nav__link', { active: currentPath === l.href }]}
          >
            {l.label}
            {l.hasMega && (
              <svg class="nav__link-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2.5 3.5L5 6L7.5 3.5" />
              </svg>
            )}
          </a>

          {/* Mega menu panel */}
          {l.hasMega && (
            <div class="mega" id="mega-panel" aria-hidden="true">
              <div class="mega__inner container">
                <div class="mega__header">
                  <p class="mega__title">Shop by Category</p>
                  <a href="/wetpets-kaustav-code/products" class="mega__view-all">
                    View All Products
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M2 6h8M7 3l3 3-3 3" />
                    </svg>
                  </a>
                </div>

                <div class="mega__grid">
                  {categoryTree.map((cat) => (
                    <a href={`/wetpets-kaustav-code/products?cat=${cat.id}`} class="mega__card" data-category={cat.id}>
                      <img src={cat.image} alt={cat.label} class="mega__card-bg" loading="lazy" />
                      <div class="mega__card-overlay"></div>
                      <div class="mega__card-content">
                        <p class="mega__card-title">{cat.label}</p>
                        <ul class="mega__card-subs">
                          {cat.subcategories.map((sub) => (
                            <li>{sub.label}</li>
                          ))}
                        </ul>
                      </div>
                      <svg class="mega__card-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M3 7h8M8 4l3 3-3 3" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Actions -->
    <div class="nav__actions">
      <a href="/wetpets-kaustav-code/contact" class="btn btn--primary nav__cta">
        <span class="nav__cta-text">Get in Touch</span>
        <svg class="nav__cta-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
        </svg>
      </a>
    </div>

    <!-- Burger -->
    <button class="nav__burger" id="nav-burger" aria-label="Toggle menu" aria-expanded="false">
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
    </button>
  </div>

  <!-- Mobile Inline Search Bar -->
  <div class="nav__mobile-search container">
    <form class="nav__mobile-search-form" action="/products" method="GET">
      <svg class="nav__mobile-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" name="q" placeholder="Search fish, tanks..." autocomplete="off" />
    </form>
  </div>

  <!-- Mobile drawer -->
  <div class="nav__drawer" id="nav-drawer" aria-hidden="true">
    {links.map((l) => (
      <>
        {l.hasMega ? (
          <div class="drawer-section">
            <button class="drawer-section__toggle" data-drawer-toggle>
              <span>{l.label}</span>
              <svg class="drawer-section__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M3 4.5L6 7.5L9 4.5" />
              </svg>
            </button>
            <div class="drawer-section__panel">
              {categoryTree.map((cat) => (
                <a href={`/wetpets-kaustav-code/products?cat=${cat.id}`} class="drawer-section__cat">
                  <img src={cat.image} alt={cat.label} class="drawer-section__cat-img" />
                  <div class="drawer-section__cat-body">
                    <span class="drawer-section__cat-name">{cat.label}</span>
                    <span class="drawer-section__cat-count">{cat.subcategories.length} subcategories</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={l.href}
            class:list={['nav__drawer-link', { active: currentPath === l.href }]}
          >
            {l.label}
          </a>
        )}
      </>
    ))}
    <a href="/wetpets-kaustav-code/contact" class="nav__drawer-link nav__drawer-link--cta">Get in Touch</a>
  </div>
</header>

<!-- Search Overlay -->
<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-overlay__backdrop" id="search-close-bg"></div>
  <div class="search-overlay__content container">
    <form class="search-overlay__form" action="/products" method="GET">
      <svg class="search-overlay__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" name="q" id="search-input" placeholder="Search for fish, tanks, equipment..." autocomplete="off" />
      <button type="button" class="search-overlay__close" id="search-close-btn" aria-label="Close search">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </form>
  </div>
</div>

<style>
  /* ── BASE NAV ──────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background-color 300ms ease, border-color 300ms ease;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background-color: rgba(8, 12, 16, 0.95);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--clr-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    height: var(--nav-h);
  }

  /* ── LOGO ──────────────────────────────────────────── */
  .nav__logo {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    flex-shrink: 0;
  }

  .nav__logo-mark {
    width: 34px;
    height: 34px;
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-dk));
    color: var(--clr-white);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
  }

  .nav__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .nav__logo-name {
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
  }

  .nav__logo-sub {
    font-size: 10px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-text-dim);
  }

  /* ── DESKTOP LINKS ─────────────────────────────────── */
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    margin-left: auto;
  }

  .nav__link-wrap {
    position: relative;
  }

  .nav__link {
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--clr-text-muted);
    letter-spacing: var(--ls-wide);
    position: relative;
    transition: color var(--dur-base) var(--ease);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .nav__link-chevron {
    transition: transform var(--dur-base) var(--ease);
    opacity: 0.6;
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--clr-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-base) var(--ease);
  }

  .nav__link:hover,
  .nav__link.active {
    color: var(--clr-text);
  }

  .nav__link:hover::after,
  .nav__link.active::after {
    transform: scaleX(1);
  }

  /* Chevron rotates when mega is open */
  .nav__link-wrap--mega:hover .nav__link-chevron,
  .nav__link-wrap--mega.mega-open .nav__link-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* ── CTA BUTTON ────────────────────────────────────── */
  .nav__cta {
    margin-left: var(--sp-6);
    padding: var(--sp-2) var(--sp-5);
    font-size: var(--fs-xs);
    background: rgba(74, 159, 216, 0.12);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(74, 159, 216, 0.25);
    color: var(--clr-accent-lt);
    box-shadow: 0 0 20px rgba(74, 159, 216, 0.08), inset 0 0 0 0.5px rgba(255, 255, 255, 0.06);
  }

  .nav__cta:hover {
    background: rgba(74, 159, 216, 0.22);
    border-color: rgba(74, 159, 216, 0.4);
    color: var(--clr-white);
    box-shadow: 0 0 28px rgba(74, 159, 216, 0.15), inset 0 0 0 0.5px rgba(255, 255, 255, 0.1);
  }

  /* ── MEGA MENU ─────────────────────────────────────── */
  .mega {
    position: fixed;
    top: var(--nav-h);
    left: 0;
    right: 0;
    background: rgba(13, 18, 24, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--clr-border);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity 280ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
      visibility 280ms,
      transform 280ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
    z-index: 99;
  }

  .nav__link-wrap--mega:hover .mega,
  .nav__link-wrap--mega.mega-open .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mega__inner {
    padding-block: var(--sp-8);
  }

  .mega__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--clr-border);
  }

  .mega__title {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-text-dim);
  }

  .mega__view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: var(--fw-semi);
    color: var(--clr-accent);
    letter-spacing: var(--ls-wide);
    transition: color var(--dur-base) var(--ease);
  }

  .mega__view-all:hover {
    color: var(--clr-accent-lt);
  }

  .mega__view-all svg {
    transition: transform var(--dur-base) var(--ease);
  }

  .mega__view-all:hover svg {
    transform: translateX(3px);
  }

  /* ── MEGA CARDS ────────────────────────────────────── */
  .mega__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--sp-4);
  }

  .mega__card {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: var(--sp-5);
    min-height: 180px;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    transition:
      border-color 280ms var(--ease),
      transform 280ms var(--ease),
      box-shadow 280ms var(--ease);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .mega__card:hover {
    border-color: var(--clr-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(74, 159, 216, 0.1);
  }

  .mega__card-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    transition: opacity 400ms var(--ease), transform 600ms var(--ease);
    z-index: 0;
  }

  .mega__card:hover .mega__card-bg {
    opacity: 0.3;
    transform: scale(1.05);
  }

  .mega__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 12, 16, 0.3) 0%, rgba(8, 12, 16, 0.85) 100%);
    z-index: 1;
  }

  .mega__card-content {
    position: relative;
    z-index: 2;
  }

  .mega__card-title {
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semi);
    color: var(--clr-text);
    margin-bottom: var(--sp-2);
    transition: color var(--dur-base) var(--ease);
  }

  .mega__card:hover .mega__card-title {
    color: var(--clr-accent-lt);
  }

  .mega__card-subs {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .mega__card-subs li {
    font-size: 11px;
    color: var(--clr-text-muted);
    line-height: 1.4;
    transition: color var(--dur-base) var(--ease);
  }

  .mega__card:hover .mega__card-subs li {
    color: var(--clr-text-muted);
  }

  .mega__card-arrow {
    position: absolute;
    top: var(--sp-5);
    right: var(--sp-5);
    color: var(--clr-text-dim);
    opacity: 0;
    transform: translateX(-4px);
    z-index: 2;
    transition:
      opacity var(--dur-base) var(--ease),
      transform var(--dur-base) var(--ease),
      color var(--dur-base) var(--ease);
  }

  .mega__card:hover .mega__card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--clr-accent);
  }

  /* ── BURGER ────────────────────────────────────────── */
  .nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    margin-left: auto;
    position: relative;
  }

  .nav__burger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background-color: var(--clr-text);
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    transition: transform var(--dur-base) var(--ease), opacity var(--dur-fast) var(--ease);
  }

  .nav__burger-line:nth-child(1) { top: 11px; }
  .nav__burger-line:nth-child(2) { top: 17px; }
  .nav__burger-line:nth-child(3) { top: 23px; }

  .nav__burger.open .nav__burger-line:nth-child(1) {
    top: 17px;
    transform: translateX(-50%) rotate(45deg);
  }

  .nav__burger.open .nav__burger-line:nth-child(2) {
    opacity: 0;
  }

  .nav__burger.open .nav__burger-line:nth-child(3) {
    top: 17px;
    transform: translateX(-50%) rotate(-45deg);
  }

  /* ── MOBILE DRAWER ─────────────────────────────────── */
  .nav__drawer {
    display: none;
    flex-direction: column;
    background-color: var(--clr-surface);
    border-top: 1px solid var(--clr-border);
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .nav__drawer.open {
    display: flex;
    max-height: 80vh;
    overflow-y: auto;
  }

  .nav__drawer-link {
    padding: var(--sp-4) var(--container-pad);
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    color: var(--clr-text-muted);
    border-bottom: 1px solid var(--clr-border);
    transition: color var(--dur-base) var(--ease), background-color var(--dur-base) var(--ease);
  }

  .nav__drawer-link:hover,
  .nav__drawer-link.active {
    color: var(--clr-text);
    background-color: rgba(74, 159, 216, 0.04);
  }

  .nav__drawer-link--cta {
    color: var(--clr-accent);
    border-bottom: none;
    margin-top: var(--sp-2);
    font-weight: var(--fw-semi);
    padding-bottom: var(--sp-6);
  }

  /* ── DRAWER EXPANDABLE SECTION ─────────────────────── */
  .drawer-section {
    border-bottom: 1px solid var(--clr-border);
  }

  .drawer-section__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--sp-4) var(--container-pad);
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-medium);
    color: var(--clr-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    transition: color var(--dur-base) var(--ease);
  }

  .drawer-section__toggle:hover {
    color: var(--clr-text);
  }

  .drawer-section__chevron {
    transition: transform 300ms var(--ease);
  }

  .drawer-section.open .drawer-section__chevron {
    transform: rotate(180deg);
  }

  .drawer-section__panel {
    display: flex;
    flex-direction: column;
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    background-color: rgba(0, 0, 0, 0.15);
  }

  .drawer-section.open .drawer-section__panel {
    max-height: 500px;
  }

  .drawer-section__cat {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--container-pad);
    padding-left: calc(var(--container-pad) + var(--sp-4));
    transition: background-color var(--dur-base) var(--ease);
  }

  .drawer-section__cat:hover {
    background-color: rgba(74, 159, 216, 0.06);
  }

  .drawer-section__cat-img {
    width: 36px;
    height: 36px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--clr-border);
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity var(--dur-base) var(--ease);
  }

  .drawer-section__cat:hover .drawer-section__cat-img {
    opacity: 1;
  }

  .drawer-section__cat-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .drawer-section__cat-name {
    font-family: var(--font-heading);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--clr-text);
  }

  .drawer-section__cat-count {
    font-size: 10px;
    color: var(--clr-text-dim);
    letter-spacing: var(--ls-wide);
  }

  .nav__cta {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .nav__cta-icon {
    display: none;
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  .nav__mobile-search {
    display: none;
    padding-bottom: var(--sp-3);
  }

  .nav__mobile-search-form {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: 8px 16px;
    gap: 12px;
    width: 100%;
  }

  .nav__mobile-search-icon {
    color: var(--clr-text-muted);
  }

  .nav__mobile-search-form input {
    background: transparent;
    border: none;
    color: var(--clr-text);
    font-size: var(--fs-sm);
    font-family: var(--font-body);
    width: 100%;
    outline: none;
  }

  .nav__mobile-search-form input::placeholder {
    color: var(--clr-text-muted);
  }

  .nav__search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-text);
    background: none;
    border: none;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease);
  }

  .nav__search-btn:hover {
    color: var(--clr-accent);
  }

  /* ── SEARCH OVERLAY ────────────────────────────────── */
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 140px;
    z-index: 200;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 300ms var(--ease), visibility 300ms;
  }

  .search-overlay.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .search-overlay__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(8, 12, 16, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 1;
  }

  .search-overlay__content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    align-items: center;
    transform: translateY(-20px);
    transition: transform 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .search-overlay.open .search-overlay__content {
    transform: translateY(0);
  }

  .search-overlay__form {
    display: flex;
    align-items: center;
    width: 100%;
    gap: var(--sp-4);
    border-bottom: 1px solid var(--clr-border);
    padding-bottom: var(--sp-4);
  }

  .search-overlay__icon {
    color: var(--clr-text-dim);
  }

  .search-overlay__form input {
    flex: 1;
    background: none;
    border: none;
    color: var(--clr-text);
    font-size: var(--fs-lg);
    font-family: var(--font-heading);
    outline: none;
  }

  .search-overlay__form input::placeholder {
    color: var(--clr-text-dim);
  }

  .search-overlay__close {
    background: none;
    border: none;
    color: var(--clr-text-muted);
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
  }

  .search-overlay__close:hover {
    color: var(--clr-accent);
    transform: rotate(90deg);
  }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav__inner {
      height: 64px; /* Fixed height for top bar */
    }

    .nav__links { display: none; }
    
    .nav__actions { 
      gap: var(--sp-2);
      margin-left: auto;
      margin-right: 12px;
    }
    
    #search-trigger-desktop { display: none; }
    
    .nav__mobile-search {
      display: block;
    }
    
    .btn--primary.nav__cta {
      padding: var(--sp-2);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      justify-content: center;
      background: transparent;
      border: none;
      box-shadow: none;
      color: var(--clr-accent);
    }
    
    .nav__cta-text {
      display: none;
    }
    
    .nav__cta-icon {
      display: block;
    }

    .nav__burger { display: flex; }
    .search-overlay__form input { font-size: var(--fs-md); }

  }

  @media (max-width: 1100px) {
    .mega__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const nav    = document.getElementById('site-nav')!;
  const burger = document.getElementById('nav-burger')!;
  const drawer = document.getElementById('nav-drawer')!;

  // ── Search Logic ──────────────────────────────────────
  const searchTriggerDesktop = document.getElementById('search-trigger-desktop')!;
  const searchOverlay        = document.getElementById('search-overlay')!;
  const searchClose          = document.getElementById('search-close-btn')!;
  const searchBg             = document.getElementById('search-close-bg')!;
  const searchInput          = document.getElementById('search-input') as HTMLInputElement;

  const toggleSearch = (force?: boolean) => {
    const isOpen = searchOverlay.classList.contains('open');
    const newState = force !== undefined ? force : !isOpen;
    
    if (newState) {
      searchOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
      setTimeout(() => searchInput?.focus(), 100);
    } else {
      searchOverlay.classList.remove('open');
      document.body.style.overflow = '';
      searchInput?.blur();
    }
  };

  searchTriggerDesktop?.addEventListener('click', () => toggleSearch(true));
  searchClose?.addEventListener('click', () => toggleSearch(false));
  searchBg?.addEventListener('click', () => toggleSearch(false));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && searchOverlay?.classList.contains('open')) {
      toggleSearch(false);
    }
  });

  // ── Scroll shadow ─────────────────────────────────────
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });
  nav.classList.toggle('scrolled', window.scrollY > 20);

  // ── Burger toggle ─────────────────────────────────────
  burger.addEventListener('click', () => {
    const isOpen = burger.classList.toggle('open');
    drawer.classList.toggle('open', isOpen);
    burger.setAttribute('aria-expanded', String(isOpen));
    drawer.setAttribute('aria-hidden', String(!isOpen));
  });

  // ── Close on link click ───────────────────────────────
  drawer.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      burger.classList.remove('open');
      drawer.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
    });
  });

  // ── Mobile drawer expandable sections ─────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-drawer-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.drawer-section')!;
      section.classList.toggle('open');
    });
  });

  // ── Mega menu: keep open while mouse is over trigger/panel ──
  const megaWrap = document.querySelector('.nav__link-wrap--mega') as HTMLElement | null;
  if (megaWrap) {
    let megaTimer: ReturnType<typeof setTimeout> | null = null;

    megaWrap.addEventListener('mouseenter', () => {
      if (megaTimer) { clearTimeout(megaTimer); megaTimer = null; }
      megaWrap.classList.add('mega-open');
    });

    megaWrap.addEventListener('mouseleave', () => {
      megaTimer = setTimeout(() => {
        megaWrap.classList.remove('mega-open');
      }, 120);
    });
  }
</script>
