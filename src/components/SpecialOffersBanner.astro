---
import { getSpecialOffers, getSpecialOfferProducts } from '../utils/sanity';

const offers = await getSpecialOffers();
const offer = offers && offers.length > 0 ? offers[0] : null;

const offerProducts = await getSpecialOfferProducts();

const livestockSubs = ['freshwater-fish','marine-fish','shrimp-inverts','live-plants','livestock-variants','combo-deals'];
const livestockOffers = offerProducts.filter((p: any) => livestockSubs.includes(p.subcategory));
const dryOffers       = offerProducts.filter((p: any) => !livestockSubs.includes(p.subcategory));

const label       = offer?.label       || 'Exclusive Deals';
const title       = offer?.title       || 'Special Offers';
const description = offer?.description || 'Handpicked combo deals and limited-time discounts — only at Wet Pets.';
const badge       = offer?.badge       || 'Up to 30% Off';
const ctaText     = offer?.ctaText     || 'Explore Deals';
const ctaLink     = offer?.ctaLink     || '/products?cat=special-offers';
const image       = offer?.image       || 'https://images.unsplash.com/photo-1524704654690-b56c05c78a00?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';

const fallbackLivestock = [
  { id: '1', name: 'Neon Tetra', discountPercent: 20 },
  { id: '2', name: 'Guppy Pair', discountPercent: 15 },
  { id: '3', name: 'Discus Fish', discountPercent: 25 },
  { id: '4', name: 'Oscar Fish', discountPercent: 18 },
];
const fallbackDry = [
  { id: '5', name: 'Sponge Filter', discountPercent: 10 },
  { id: '6', name: 'Fish Food Combo', discountPercent: 30 },
  { id: '7', name: 'Aquarium Lights', discountPercent: 18 },
  { id: '8', name: 'Water Conditioner', discountPercent: 12 },
];

const liveSlide = livestockOffers.length > 0 ? livestockOffers : fallbackLivestock;
const drySlide  = dryOffers.length > 0 ? dryOffers : fallbackDry;
---

<section class="so-section" id="special-offers">
  <div class="container">
    <div class="so-wrapper reveal">

      <!-- ── Left Panel ───────────────────── -->
      <div class="so-left">
        <span class="so-eyebrow">{label}</span>
        <h2 class="so-title">{title}</h2>
        <p class="so-desc">{description}</p>
        <a href={ctaLink} class="so-cta">
          {ctaText}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 8h10M9 4l4 4-4 4"/>
          </svg>
        </a>
      </div>

      <!-- ── Right Panel: Offer Card ─────── -->
      <div class="so-right">
        <div class="so-card" id="so-card">

          <!-- Fish image backdrop -->
          <img src={image} alt="Special Offers" class="so-card__bg" loading="lazy" />
          <div class="so-card__tint"></div>

          <!-- Tab bar -->
          <div class="so-tabs" id="so-tabs">
            <button class="so-tab active" data-tab="0" id="tab-0">
              <span class="so-tab__icon">🐟</span>
              <span>Livestock</span>
            </button>
            <button class="so-tab" data-tab="1" id="tab-1">
              <span class="so-tab__icon">📦</span>
              <span>Dry Goods</span>
            </button>
            <!-- Animated ink underline -->
            <span class="so-tab__ink" id="so-ink"></span>
          </div>

          <!-- Panels -->
          <div class="so-panels" id="so-panels">
            <!-- Floating badge inside panels -->
            <div class="so-card__badge">{badge}</div>

            <!-- Panel 0: Livestock -->
            <div class="so-panel active" data-panel="0">
              {liveSlide.map((p: any) => (
                <div class="so-item">
                  <span class="so-item__name">{p.name}</span>
                  {p.discountPercent
                    ? <span class="so-item__pill so-item__pill--green">{p.discountPercent}% OFF</span>
                    : <span class="so-item__pill so-item__pill--blue">On Offer</span>
                  }
                </div>
              ))}
            </div>

            <!-- Panel 1: Dry Goods -->
            <div class="so-panel" data-panel="1">
              {drySlide.map((p: any) => (
                <div class="so-item">
                  <span class="so-item__name">{p.name}</span>
                  {p.discountPercent
                    ? <span class="so-item__pill so-item__pill--amber">{p.discountPercent}% OFF</span>
                    : <span class="so-item__pill so-item__pill--blue">On Offer</span>
                  }
                </div>
              ))}
            </div>
          </div>

          <!-- Progress bar -->
          <div class="so-progress" id="so-progress">
            <div class="so-progress__bar" id="so-progress-bar"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* ── Section ─────────────────────────────────── */
.so-section {
  padding-block: var(--sp-16);
  position: relative;
  overflow: hidden;
}

.so-section::before {
  content: '';
  position: absolute;
  top: 50%; left: 5%;
  width: 700px; height: 700px;
  background: radial-gradient(circle, rgba(74,159,216,0.07) 0%, transparent 68%);
  transform: translateY(-50%);
  border-radius: 50%;
  z-index: 0; pointer-events: none;
}

/* ── Wrapper grid ────────────────────────────── */
.so-wrapper {
  position: relative; z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: clamp(var(--sp-8), 5vw, var(--sp-16));
  align-items: center;
  background: rgba(14,20,28,0.55);
  border: 1px solid rgba(74,159,216,0.12);
  border-radius: 20px;
  padding: clamp(var(--sp-8), 4vw, var(--sp-12));
  box-shadow: 0 24px 60px rgba(0,0,0,0.45),
              inset 0 1px 0 rgba(255,255,255,0.04);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

/* ── Left panel ──────────────────────────────── */
.so-left { display: flex; flex-direction: column; gap: var(--sp-5); }

.so-eyebrow {
  font-family: var(--font-heading);
  font-size: 11px; font-weight: var(--fw-bold);
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--clr-accent-lt);
}

.so-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 900; line-height: 1.1;
  color: var(--clr-text);
}

.so-desc {
  font-size: var(--fs-md);
  color: var(--clr-text-muted);
  line-height: var(--lh-relaxed);
  max-width: 38ch;
}

.so-cta {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-dk));
  color: #fff;
  font-family: var(--font-heading);
  font-size: var(--fs-sm); font-weight: var(--fw-bold);
  letter-spacing: var(--ls-wide);
  padding: var(--sp-3) var(--sp-6);
  border-radius: var(--radius-full);
  align-self: flex-start;
  box-shadow: 0 6px 24px rgba(74,159,216,0.3);
  transition: box-shadow 250ms, transform 250ms;
}
.so-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 32px rgba(74,159,216,0.45);
}
.so-cta svg { transition: transform 250ms; }
.so-cta:hover svg { transform: translateX(3px); }

/* ── Right card ──────────────────────────────── */
.so-right { display: flex; justify-content: center; align-items: center; }

.so-card {
  position: relative;
  width: 100%; max-width: 480px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 20px 48px rgba(0,0,0,0.55);
}

.so-card__bg {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0.18;
  filter: saturate(0.7);
}

.so-card__tint {
  position: absolute; inset: 0;
  background: linear-gradient(160deg,
    rgba(8,14,22,0.88) 0%,
    rgba(8,14,22,0.78) 60%,
    rgba(10,18,30,0.92) 100%);
  z-index: 1;
}

/* Badge */
.so-card__badge {
  position: absolute; bottom: 14px; right: 14px; z-index: 4;
  background: linear-gradient(135deg, #4a9fd8, #2563a8);
  color: #fff;
  font-family: var(--font-heading);
  font-size: 10px; font-weight: var(--fw-bold);
  letter-spacing: 0.12em; text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 20px;
  box-shadow: 0 4px 14px rgba(74,159,216,0.4);
  pointer-events: none;
}

/* ── Tabs ────────────────────────────────────── */
.so-tabs {
  position: relative; z-index: 2;
  display: flex;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  background: rgba(0,0,0,0.25);
  backdrop-filter: blur(8px);
}

.so-tab {
  flex: 1;
  display: flex; align-items: center; justify-content: center; gap: 6px;
  padding: 13px 16px;
  background: none; border: none; cursor: pointer;
  font-family: var(--font-heading);
  font-size: var(--fs-sm); font-weight: var(--fw-semi);
  color: rgba(255,255,255,0.45);
  transition: color 250ms;
  position: relative;
}

.so-tab.active { color: #fff; }
.so-tab:hover:not(.active) { color: rgba(255,255,255,0.7); }

.so-tab__icon { font-size: 15px; }

/* Animated ink underline */
.so-tab__ink {
  position: absolute;
  bottom: 0; left: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--clr-accent), #60b8f0);
  border-radius: 1px;
  transition: left 300ms cubic-bezier(0.4,0,0.2,1),
              width 300ms cubic-bezier(0.4,0,0.2,1);
  z-index: 3;
}

/* ── Panels ──────────────────────────────────── */
.so-panels {
  position: relative; z-index: 2;
  padding: 16px;
  min-height: 220px;
}

.so-panel {
  display: none;
  flex-direction: column;
  gap: 8px;
  animation: panelIn 280ms ease both;
}

.so-panel.active { display: flex; }

@keyframes panelIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Item rows ───────────────────────────────── */
.so-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 14px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  transition: background 200ms, border-color 200ms;
}

.so-item:hover {
  background: rgba(74,159,216,0.08);
  border-color: rgba(74,159,216,0.2);
}

.so-item__name {
  font-family: var(--font-heading);
  font-size: var(--fs-sm); font-weight: var(--fw-medium);
  color: #e8eef4;
  white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis;
  max-width: 65%;
}

.so-item__pill {
  font-family: var(--font-heading);
  font-size: 10px; font-weight: var(--fw-bold);
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 3px 10px; border-radius: 20px;
  flex-shrink: 0;
}

.so-item__pill--green {
  color: #4ade80;
  background: rgba(74,222,128,0.1);
  border: 1px solid rgba(74,222,128,0.22);
}

.so-item__pill--amber {
  color: #fbbf24;
  background: rgba(251,191,36,0.1);
  border: 1px solid rgba(251,191,36,0.22);
}

.so-item__pill--blue {
  color: #60b8f0;
  background: rgba(96,184,240,0.1);
  border: 1px solid rgba(96,184,240,0.22);
}

/* ── Progress bar ────────────────────────────── */
.so-progress {
  position: relative; z-index: 2;
  height: 3px;
  background: rgba(255,255,255,0.07);
}

.so-progress__bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--clr-accent), #60b8f0);
  transition: width linear;
  border-radius: 0 2px 2px 0;
}

/* ── Responsive ──────────────────────────────── */
@media (max-width: 900px) {
  .so-wrapper { grid-template-columns: 1fr; gap: var(--sp-8); }
  .so-right { order: -1; }
  .so-section::before { display: none; }
  .so-card { max-width: 100%; }
}

@media (max-width: 560px) {
  .so-title { font-size: 1.8rem; }
  .so-desc { font-size: var(--fs-sm); }
  .so-panels { min-height: 190px; }
}
</style>

<script>
  const INTERVAL = 4000; // 4 seconds per slide

  const tabs     = document.querySelectorAll<HTMLButtonElement>('.so-tab');
  const panels   = document.querySelectorAll<HTMLElement>('.so-panel');
  const ink      = document.getElementById('so-ink')!;
  const progressBar = document.getElementById('so-progress-bar')!;

  let current = 0;
  let timer: ReturnType<typeof setInterval>;
  let progressTimer: ReturnType<typeof setInterval>;

  function moveInk(tab: HTMLButtonElement) {
    ink.style.left  = tab.offsetLeft + 'px';
    ink.style.width = tab.offsetWidth + 'px';
  }

  function goTo(idx: number) {
    // tabs
    tabs.forEach((t, i) => t.classList.toggle('active', i === idx));
    // panels
    panels.forEach((p, i) => p.classList.toggle('active', i === idx));
    // ink
    moveInk(tabs[idx]);
    current = idx;
    // reset progress
    resetProgress();
  }

  function resetProgress() {
    progressBar.style.transition = 'none';
    progressBar.style.width = '0%';
    // force reflow
    void progressBar.offsetWidth;
    progressBar.style.transition = `width ${INTERVAL}ms linear`;
    progressBar.style.width = '100%';
  }

  function startAuto() {
    timer = setInterval(() => {
      goTo((current + 1) % tabs.length);
    }, INTERVAL);
  }

  function stopAuto() {
    clearInterval(timer);
  }

  // Click tabs
  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      stopAuto();
      goTo(i);
      startAuto(); // restart timer from this tab
    });
  });

  // Init
  goTo(0);
  startAuto();

  // Pause on hover
  const card = document.getElementById('so-card');
  card?.addEventListener('mouseenter', stopAuto);
  card?.addEventListener('mouseleave', () => { stopAuto(); startAuto(); });
</script>
