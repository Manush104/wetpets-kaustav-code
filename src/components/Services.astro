---
const services = [
  {
    title: 'Live Fish',
    desc: 'Hundreds of freshwater species — imported and locally bred. Tetras, Cichlids, Arowana, Betta, Goldfish and more.',
    img: '/assets/images/services/service-fish.jpg',
  },
  {
    title: 'Aquariums & Tanks',
    desc: 'Glass and acrylic tanks from compact nano setups to large display aquariums. Custom sizes on request.',
    img: '/assets/images/services/service-tanks.jpg',
  },
  {
    title: 'Filters & Equipment',
    desc: 'Canister filters, sponge filters, heaters, air pumps, LED lights, CO₂ systems and water treatment.',
    img: '/assets/images/services/service-equipment.jpg',
  },
  {
    title: 'Plants & Decor',
    desc: 'Live aquatic plants, driftwood, rocks, substrate, and ornaments for aquascaping.',
    img: '/assets/images/services/service-plants.jpg',
  },
  {
    title: 'Fish Food & Care',
    desc: 'Flakes, pellets, frozen bloodworms, live food, medications and water conditioners.',
    img: '/assets/images/services/service-food.jpg',
  },
  {
    title: 'Expert Guidance',
    desc: 'Free advice on setup, water chemistry, fish compatibility and disease treatment from our experienced team.',
    img: '/assets/images/services/service-advice.jpg',
  },
];
---

<section class="services section" id="services">
  <div class="container">
    <div class="section-header reveal">
      <p class="label">What We Offer</p>
      <div class="divider"></div>
      <h2 class="h2">Everything for Your Aquarium</h2>
      <p>We carry a full range of aquarium products — from the fish to the tank to every accessory in between.</p>
    </div>

    <div class="services__grid">
      {services.map((svc, i) => (
        <div class={`services__card reveal${i % 3 === 1 ? ' reveal-delay-1' : i % 3 === 2 ? ' reveal-delay-2' : ''}`}>
          <div class="services__card-img">
            <img src={svc.img} alt={svc.title} loading="lazy" />
          </div>
          <div class="services__card-body">
            <h3 class="h4">{svc.title}</h3>
            <p>{svc.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-3);
  }

  .services__card {
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--dur-base) var(--ease);
  }

  .services__card:hover {
    border-color: var(--clr-border-2);
  }

  .services__card-img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--clr-surface-2);
  }

  .services__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms var(--ease);
    filter: brightness(0.7) saturate(0.7);
  }

  .services__card:hover .services__card-img img {
    transform: scale(1.05);
    filter: brightness(0.85) saturate(0.85);
  }

  .services__card-body {
    padding: var(--sp-5);
  }

  .services__card-body h3 {
    color: var(--clr-text);
    margin-bottom: var(--sp-2);
  }

  .services__card-body p {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
  }

  @media (max-width: 900px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
