---

<section class="contact section" id="contact-section">
  <!-- CTA band -->
  <div class="contact__cta">
    <div class="container contact__cta-inner">
      <div class="reveal">
        <p class="label">Get in Touch</p>
        <h2 class="h2" style="margin-top: var(--sp-3);">Interested in Our Products?</h2>
        <p class="contact__cta-desc text-muted">
          Call us or send a WhatsApp message — we're always happy to help.
        </p>
      </div>
      <div class="contact__cta-btns reveal reveal-delay-2">
        <a href="https://wa.me/918910518028?text=Hi%2C+I%27d+like+to+enquire+about+your+products." target="_blank" rel="noopener" class="btn btn--whatsapp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
        <span class="btn btn--outline" style="cursor: default;">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"><path d="M3 2h4l1.5 4-2 1.5a10.5 10.5 0 005 5L13 10.5l4 1.5v4a1 1 0 01-1 1C5 17 1 7.5 1 3a1 1 0 012-1z"/></svg>
          Call: +91 89105 18028
        </span>
        <a href="#" target="_blank" rel="noopener" class="btn btn--outline" id="facebook-link" style="border-color: #1877F2; color: #1877F2;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.312h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/>
          </svg>
          Facebook
        </a>
      </div>
    </div>
  </div>

  <!-- Info cards + Map -->
  <div class="container contact__body">
    <div class="contact__grid">
      <div class="contact__card reveal" id="contact-address">
        <div class="contact__card-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2C7.239 2 5 4.239 5 7c0 4.5 5 10 5 10s5-5.5 5-10c0-2.761-2.239-5-5-5z" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="7" r="1.5" stroke="currentColor" stroke-width="1.4"/></svg>
        </div>
        <h3 class="h4">Location</h3>
        <p class="contact__card-text">
          Natagarh, Kolkata<br />
          West Bengal, India
        </p>
      </div>

      <div class="contact__card reveal reveal-delay-1" id="contact-hours">
        <div class="contact__card-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"/><path d="M10 5v5l3.5 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="square"/></svg>
        </div>
        <h3 class="h4">Hours</h3>
        <div class="contact__hours">
          <div class="contact__hours-row">
            <span>Monday — Sunday</span>
            <span class="contact__hours-badge">
              <span class="contact__dot"></span>
              Open 24 Hrs
            </span>
          </div>
        </div>
      </div>

      <div class="contact__card reveal reveal-delay-2" id="contact-info">
        <div class="contact__card-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 3h14v14H3z" stroke="currentColor" stroke-width="1.4"/><path d="M3 3l7 7 7-7" stroke="currentColor" stroke-width="1.4"/></svg>
        </div>
        <h3 class="h4">Contact</h3>
        <span class="contact__link" style="cursor: default;">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3"><path d="M2 1.5h3.5L7 5l-1.75 1.25c.9 2.1 2.5 3.65 4.5 4.5L11 9l3.5 1.5v3.5C10 15.5 1 7 2 1.5z"/></svg>
          +91 89105 18028
        </span>
      </div>
    </div>

    <!-- Google Maps embed -->
    <div class="contact__map reveal">
      <iframe
        class="contact__map-iframe"
        src="https://maps.google.com/maps?width=600&amp;height=400&amp;hl=en&amp;q=WET PETS natagarh&amp;t=h&amp;z=18&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"
        width="100%"
        height="320"
        frameborder="0"
        scrolling="no"
        marginheight="0"
        marginwidth="0"
        loading="lazy"
        title="Wet Pets location on Google Maps"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--clr-surface);
    border-top: 1px solid var(--clr-border);
    padding-top: 0;
  }

  .contact__cta {
    background-color: var(--clr-surface-2);
    border-bottom: 1px solid var(--clr-border);
    padding-block: clamp(var(--sp-12), 5vw, var(--sp-20));
  }

  .contact__cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-8);
    flex-wrap: wrap;
  }

  .contact__cta-desc {
    margin-top: var(--sp-3);
    max-width: 40ch;
    line-height: var(--lh-relaxed);
  }

  .contact__cta-btns {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .contact__body {
    padding-block: clamp(var(--sp-12), 5vw, var(--sp-20));
  }

  .contact__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-3);
  }

  .contact__card {
    padding: var(--sp-6);
    border: 1px solid var(--clr-border);
    background-color: var(--clr-surface-3);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .contact__card-icon {
    width: 40px;
    height: 40px;
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-accent);
  }

  .contact__card-text {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    transition: color var(--dur-base) var(--ease);
  }

  .contact__link:hover {
    color: var(--clr-accent);
  }

  .contact__hours-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
  }

  .contact__hours-badge {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-accent);
  }

  .contact__dot {
    width: 6px;
    height: 6px;
    background-color: var(--clr-accent);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Google Maps */
  .contact__map {
    margin-top: var(--sp-6);
    overflow: hidden;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background-color: var(--clr-surface-2);
  }

  .contact__map-iframe {
    display: block;
    width: 100%;
    height: 320px;
    border: 0;
    filter: brightness(0.85) contrast(1.1) saturate(0.8);
  }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; }
    .contact__cta-inner { flex-direction: column; align-items: flex-start; }
    .contact__map-iframe { height: 260px; }
  }
</style>
