---
import type { Product } from '../data/products';
import { categoryTree } from '../data/products';

interface Props {
  product: Product;
  whatsappNumber?: string;
}

const {
  product,
  whatsappNumber = '918910518028',
} = Astro.props;

// Resolve subcategory label from the tree
const catGroup = categoryTree.find(c => c.id === product.category);
const subLabel = catGroup?.subcategories.find(s => s.id === product.subcategory)?.label ?? product.subcategory;

const whatsappText = encodeURIComponent(
  `Hi, I'm interested in "${product.name}" (₹${product.price}${product.priceLabel ? ' ' + product.priceLabel : ''}). Is it available?`
);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappText}`;
---

<article class="prod-card" id={`product-${product.id}`}>
  <div class="prod-card__img-wrap">
    <img src={product.image} alt={product.name} loading="lazy" class="prod-card__img" />
    <span class="prod-card__badge">{subLabel}</span>
    {!product.inStock && <span class="prod-card__oos">Out of Stock</span>}
  </div>

  <div class="prod-card__body">
    <h3 class="prod-card__name">{product.name}</h3>
    <p class="prod-card__desc">{product.description}</p>

    <div class="prod-card__footer">
      <div class="prod-card__price">
        <span class="prod-card__price-amount">₹{product.price.toLocaleString('en-IN')}</span>
        {product.priceLabel && (
          <span class="prod-card__price-label">{product.priceLabel}</span>
        )}
      </div>

      <div class="prod-card__actions">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener"
          class="prod-card__btn prod-card__btn--wa"
          title="Enquire on WhatsApp"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a
          href="tel:+918910518028"
          class="prod-card__btn prod-card__btn--call"
          title="Call to enquire"
        >
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square">
            <path d="M3 2h4l1.5 4-2 1.5a10.5 10.5 0 005 5L13 10.5l4 1.5v4a1 1 0 01-1 1C5 17 1 7.5 1 3a1 1 0 012-1z"/>
          </svg>
          Call
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .prod-card {
    background-color: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color var(--dur-base) var(--ease);
  }

  .prod-card:hover {
    border-color: var(--clr-border-2);
  }

  .prod-card__img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--clr-surface-2);
  }

  .prod-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms var(--ease);
    filter: brightness(0.85);
  }

  .prod-card:hover .prod-card__img {
    transform: scale(1.05);
    filter: brightness(1);
  }

  .prod-card__badge {
    position: absolute;
    top: var(--sp-3);
    left: var(--sp-3);
    background-color: var(--clr-bg);
    color: var(--clr-accent);
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
  }

  .prod-card__oos {
    position: absolute;
    top: var(--sp-3);
    right: var(--sp-3);
    background-color: rgba(8, 12, 16, 0.85);
    color: #ef4444;
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-sm);
  }

  .prod-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--sp-5);
    gap: var(--sp-3);
  }

  .prod-card__name {
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: var(--fw-semi);
    color: var(--clr-text);
  }

  .prod-card__desc {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
    flex: 1;
  }

  .prod-card__footer {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--clr-border);
    margin-top: auto;
  }

  .prod-card__price {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .prod-card__price-amount {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
  }

  .prod-card__price-label {
    font-size: 10px;
    color: var(--clr-text-dim);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .prod-card__actions {
    display: flex;
    gap: var(--sp-2);
  }

  .prod-card__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-3);
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    transition: background-color var(--dur-base) var(--ease), color var(--dur-base) var(--ease);
  }

  .prod-card__btn--wa {
    background-color: var(--clr-whatsapp);
    color: var(--clr-white);
  }
  .prod-card__btn--wa:hover {
    background-color: #22c55e;
  }

  .prod-card__btn--call {
    border: 1px solid var(--clr-border-2);
    color: var(--clr-text-muted);
  }
  .prod-card__btn--call:hover {
    border-color: var(--clr-accent);
    color: var(--clr-accent);
  }

  @media (max-width: 480px) {
    .prod-card__body { padding: var(--sp-3); gap: var(--sp-2); }
    .prod-card__name { font-size: 14px; }
    .prod-card__desc { font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .prod-card__badge { transform: scale(0.85); transform-origin: top left; }
    .prod-card__footer { gap: var(--sp-2); padding-top: var(--sp-3); }
    .prod-card__actions { gap: var(--sp-1); display: grid; grid-template-columns: 1fr 1fr; }
    .prod-card__btn { justify-content: center; padding: var(--sp-2) var(--sp-1); font-size: 9px; }
  }
</style>
