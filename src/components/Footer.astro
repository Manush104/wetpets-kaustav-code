---
const searchTerms = [
  'Imported Aquarium Fish', 'Aquarium Gold Fish', 'Discus Fish',
  'Arowana Fish', 'Flowerhorn Fish', 'Guppy Fish',
  'Clownfish', 'Fancy Goldfish', 'Neon Tetra',
  'African Cichlid', 'Gourami Fish', 'Freshwater Shark',
  'Glass Aquarium', 'Siamese Fighting Fish', 'Clown Loach',
  'Oscar Fish', 'Catfish', 'Angelfish',
  'Balloon Molly Fish', 'Tiger Oscar', 'Oranda Goldfish',
  'Cardinal Tetra', 'Black Molly', 'Redtail Shark',
  'Parrot Fish', 'Bichir', 'Piranha',
  'Bala Shark', 'Koi Fish', 'Sponge Filter',
  'Denison Barb', 'Aquarium Plants', 'Fish Food',
];
---

<footer class="footer" id="footer">
  <div class="container footer__top">
    <div class="footer__brand">
      <a href="/wetpets-kaustav-code/" class="footer__logo">
        <span class="footer__logo-mark">WP</span>
        <div>
          <p class="footer__logo-name">Wet Pets</p>
          <p class="footer__logo-sub">Aquarium Store · Kolkata</p>
        </div>
      </a>
      <p class="footer__tagline">
        Your trusted source for ornamental fish, aquariums, and accessories.
        Open 24/7, every day.
      </p>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <p class="footer__col-title">Pages</p>
        <ul>
          <li><a href="/wetpets-kaustav-code/">Home</a></li>
          <li><a href="/wetpets-kaustav-code/products">Products</a></li>
          <li><a href="/wetpets-kaustav-code/about">About Us</a></li>
          <li><a href="/wetpets-kaustav-code/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__col-title">Products</p>
        <ul>
          <li><a href="/wetpets-kaustav-code/products?cat=livestock">Livestock</a></li>
          <li><a href="/wetpets-kaustav-code/products?cat=tanks">Tanks & Furniture</a></li>
          <li><a href="/wetpets-kaustav-code/products?cat=equipment">Equipment</a></li>
          <li><a href="/wetpets-kaustav-code/products?cat=maintenance">Maintenance</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__col-title">Info</p>
        <ul>
          <li>
            <span class="footer__open">
              <span class="footer__open-dot"></span>
              Open 24 / 7
            </span>
          </li>
          <li style="color: var(--clr-text-dim); font-size: var(--fs-sm);">Kolkata, West Bengal</li>
          <li><a href="https://wa.me/918910518028" target="_blank" rel="noopener">WhatsApp Us</a></li>
          <li><a href="tel:+918910518028">Call: +91 89105 18028</a></li>
          <li><a href="#" target="_blank" rel="noopener">Facebook</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- SEO tags -->
  <div class="footer__tags-section">
    <div class="container">
      <p class="footer__tags-head">Related Searches</p>
      <div class="footer__tags">
        {searchTerms.map((t) => (
          <span class="footer__tag">{t}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {new Date().getFullYear()} Wet Pets. All rights reserved. Made by Webdue Solutions.</p>
      <p style="color: var(--clr-text-dim);">Kolkata, India</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--clr-surface);
    border-top: 1px solid var(--clr-border);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: clamp(var(--sp-10), 5vw, var(--sp-20));
    padding-block: clamp(var(--sp-12), 5vw, var(--sp-20));
    align-items: start;
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-5);
  }

  .footer__logo-mark {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, var(--clr-accent), var(--clr-accent-dk));
    color: var(--clr-white);
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
  }

  .footer__logo-name {
    font-family: var(--font-heading);
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    color: var(--clr-text);
  }

  .footer__logo-sub {
    font-size: 10px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-text-dim);
  }

  .footer__tagline {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
    max-width: 35ch;
  }

  /* Columns */
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .footer__col-title {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-text);
    margin-bottom: var(--sp-4);
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer__col a {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    transition: color var(--dur-base) var(--ease);
  }

  .footer__col a:hover { color: var(--clr-accent); }

  .footer__open {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-accent);
  }

  .footer__open-dot {
    width: 6px;
    height: 6px;
    background-color: var(--clr-accent);
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Tags */
  .footer__tags-section {
    border-top: 1px solid var(--clr-border);
    padding-block: var(--sp-6);
  }

  .footer__tags-head {
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-text-dim);
    margin-bottom: var(--sp-3);
  }

  .footer__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .footer__tag {
    font-size: 10px;
    color: var(--clr-text-dim);
    border: 1px solid var(--clr-border);
    padding: 2px var(--sp-3);
    letter-spacing: 0.02em;
    border-radius: var(--radius-sm);
    transition: color var(--dur-base), border-color var(--dur-base);
    cursor: default;
  }

  .footer__tag:hover {
    color: var(--clr-text-muted);
    border-color: var(--clr-border-2);
  }

  /* Bottom */
  .footer__bottom {
    border-top: 1px solid var(--clr-border);
    padding-block: var(--sp-4);
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-4);
    flex-wrap: wrap;
    font-size: var(--fs-xs);
    color: var(--clr-text-muted);
  }

  @media (max-width: 768px) {
    .footer__top { grid-template-columns: 1fr; }
    .footer__cols { grid-template-columns: repeat(2, 1fr); }
    .footer__bottom-inner { flex-direction: column; }
  }
</style>
