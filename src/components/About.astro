---
---

<section class="about section" id="about">
  <div class="container about__inner">
    <div class="about__text">
      <p class="label reveal">Our Story</p>
      <div class="divider reveal reveal-delay-1"></div>
      <h2 class="h2 reveal reveal-delay-1">
        Your Trusted Source<br />for Aquatic Life
      </h2>
      <p class="about__body reveal reveal-delay-2">
        Wet Pets is Kolkata's go-to destination for aquarium enthusiasts — from
        first-time fish keepers to seasoned hobbyists. We stock a vast selection
        of ornamental fish, both imported and locally bred, along with everything
        you need to build and maintain a thriving aquatic environment.
      </p>
      <p class="about__body reveal reveal-delay-3">
        Whether you're looking for a rare Flowerhorn, setting up a planted tank, or
        simply picking up fish food — you'll find it all here. Our team is always
        happy to help with advice, sourcing, and recommendations.
      </p>

      <ul class="about__checks reveal reveal-delay-3">
        <li class="about__check">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/></svg>
          Wide variety of ornamental fish, always in stock
        </li>
        <li class="about__check">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/></svg>
          Glass & acrylic aquariums in all sizes
        </li>
        <li class="about__check">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/></svg>
          Filters, heaters, lights & accessories
        </li>
        <li class="about__check">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="square"/></svg>
          Friendly expert advice, always
        </li>
      </ul>

      <a href="/wetpets-kaustav-code/about" class="btn btn--ghost reveal reveal-delay-4">
        Learn More About Us
        <svg class="arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 8h12M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </a>
    </div>

    <div class="about__gallery">
      <div class="about__img-main reveal reveal-delay-1">
        <img src="/wetpets-kaustav-code/assets/images/store/store-front.jpg" alt="Wet Pets Storefront" />
      </div>
      <div class="about__img-row">
        <div class="about__img-sm reveal reveal-delay-2">
          <img src="/wetpets-kaustav-code/assets/images/store/tank-1-new.jpg" alt="Wet Pets display tank 1" />
        </div>
        <div class="about__img-sm reveal reveal-delay-3">
          <img src="/wetpets-kaustav-code/assets/images/store/tank-2-new.png" alt="Wet Pets display tank 2" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--sp-10), 5vw, var(--sp-20));
    align-items: center;
  }

  .about__body {
    margin-top: var(--sp-4);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
  }

  .about__checks {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
    margin-bottom: var(--sp-6);
  }

  .about__check {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
  }

  .about__check svg {
    color: var(--clr-accent);
    flex-shrink: 0;
  }

  /* Gallery */
  .about__gallery {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .about__img-main {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--clr-surface-2);
    border-radius: var(--radius-md);
  }

  .about__img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease);
  }

  .about__img-main:hover img {
    transform: scale(1.04);
  }

  .about__img-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-3);
  }

  .about__img-sm {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: var(--clr-surface-2);
    border-radius: var(--radius-md);
  }

  .about__img-sm img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease);
  }

  .about__img-sm:hover img {
    transform: scale(1.06);
  }

  @media (max-width: 900px) {
    .about__inner { grid-template-columns: 1fr; }
    .about__gallery { order: -1; }
    .about__img-main { aspect-ratio: 16 / 9; }
  }
</style>
