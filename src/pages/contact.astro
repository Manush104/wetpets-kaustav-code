---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout
  title="Contact — Wet Pets Aquarium Store, Kolkata"
  description="Get in touch with Wet Pets via WhatsApp or phone. Open 24 hours, 7 days a week in Kolkata."
>
  <Nav />
  <main id="main-content">
    <!-- Page header -->
    <section class="page-hero">
      <div class="container">
        <p class="label reveal">Contact Us</p>
        <h1 class="h2 reveal reveal-delay-1" style="margin-top: var(--sp-3);">Get in Touch</h1>
        <p class="page-hero__desc reveal reveal-delay-2">
          We're always happy to help. Reach out via WhatsApp, call us, or visit the store.
        </p>
      </div>
    </section>

    <!-- Contact cards -->
    <section class="section">
      <div class="container">
        <div class="contact-grid">
          <!-- WhatsApp -->
          <div class="contact-card contact-card--wa reveal">
            <div class="contact-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <h2 class="h3">WhatsApp</h2>
            <p class="contact-card__desc">Fastest way to reach us. Tap below to start a conversation.</p>
            <a
              href="https://wa.me/918910518028?text=Hi%2C+I%27d+like+to+enquire+about+your+products."
              target="_blank"
              rel="noopener"
              class="btn btn--whatsapp"
              style="margin-top: var(--sp-4);"
            >Message Us on WhatsApp</a>
          </div>

          <!-- Phone -->
          <div class="contact-card reveal reveal-delay-1">
            <div class="contact-card__icon">
              <svg width="22" height="22" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
                <path d="M3 2h4l1.5 4-2 1.5a10.5 10.5 0 005 5L13 10.5l4 1.5v4a1 1 0 01-1 1C5 17 1 7.5 1 3a1 1 0 012-1z"/>
              </svg>
            </div>
            <h2 class="h3">Call Us</h2>
            <p class="contact-card__desc">Give us a ring anytime — we're open 24/7.</p>
            <a href="tel:+918910518028" class="btn btn--outline" style="margin-top: var(--sp-4);">
              +91 89105 18028
            </a>
          </div>

          <!-- Visit -->
          <div class="contact-card reveal reveal-delay-2">
            <div class="contact-card__icon">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4">
                <path d="M10 2C7.239 2 5 4.239 5 7c0 4.5 5 10 5 10s5-5.5 5-10c0-2.761-2.239-5-5-5z"/>
                <circle cx="10" cy="7" r="1.5"/>
              </svg>
            </div>
            <h2 class="h3">Visit Us</h2>
            <p class="contact-card__desc">
              Natagarh, Kolkata<br />
              West Bengal, India
            </p>
          </div>
        </div>

        <!-- Hours -->
        <div class="hours-bar reveal" style="margin-top: var(--sp-6);">
          <div class="hours-bar__inner">
            <div class="hours-bar__left">
              <span class="hours-bar__dot"></span>
              <div>
                <p class="h4">Open 24 Hours</p>
                <p class="text-muted" style="font-size: var(--fs-sm);">Monday — Sunday, including holidays</p>
              </div>
            </div>
            <div class="hours-bar__badge">Always Open</div>
          </div>
        </div>

        <!-- Google Maps -->
        <div class="map-embed reveal" style="margin-top: var(--sp-6);">
          <iframe
            class="map-embed__iframe"
            src="https://maps.google.com/maps?width=600&amp;height=400&amp;hl=en&amp;q=WET PETS natagarh&amp;t=h&amp;z=18&amp;ie=UTF8&amp;iwloc=B&amp;output=embed"
            width="100%"
            height="360"
            frameborder="0"
            scrolling="no"
            marginheight="0"
            marginwidth="0"
            loading="lazy"
            title="Wet Pets location on Google Maps"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FAQ />
  </main>
  <Footer />
  <WhatsAppFloat />
</Layout>

<style>
  .page-hero {
    padding-top: calc(var(--nav-h) + var(--sp-16));
    padding-bottom: var(--sp-12);
    background-color: var(--clr-surface);
    border-bottom: 1px solid var(--clr-border);
  }

  .page-hero__desc {
    margin-top: var(--sp-4);
    color: var(--clr-text-muted);
    max-width: 50ch;
    line-height: var(--lh-relaxed);
  }

  /* Contact grid */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-3);
  }

  .contact-card {
    padding: var(--sp-8);
    border: 1px solid var(--clr-border);
    background-color: var(--clr-surface);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .contact-card--wa {
    background-color: var(--clr-surface-2);
    border-color: rgba(37, 211, 102, 0.2);
  }

  .contact-card__icon {
    width: 44px;
    height: 44px;
    background-color: var(--clr-surface-3);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-accent);
  }

  .contact-card--wa .contact-card__icon {
    color: var(--clr-whatsapp);
  }

  .contact-card__desc {
    font-size: var(--fs-sm);
    color: var(--clr-text-muted);
    line-height: var(--lh-relaxed);
  }

  /* Hours bar */
  .hours-bar {
    border: 1px solid var(--clr-border);
    background-color: var(--clr-surface);
    padding: var(--sp-6);
    border-radius: var(--radius-md);
  }

  .hours-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    flex-wrap: wrap;
  }

  .hours-bar__left {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  .hours-bar__dot {
    width: 10px;
    height: 10px;
    background-color: var(--clr-accent);
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hours-bar__badge {
    font-family: var(--font-heading);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--clr-accent);
    border: 1px solid var(--clr-accent);
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-sm);
  }

  /* Map */
  .map-embed {
    overflow: hidden;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background-color: var(--clr-surface-2);
  }

  .map-embed__iframe {
    display: block;
    width: 100%;
    height: 360px;
    border: 0;
    filter: brightness(0.85) contrast(1.1) saturate(0.8);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .map-embed__iframe { height: 280px; }
  }
</style>
